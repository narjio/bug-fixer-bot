rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read/write settings (like recaptcha siteKey)
    // Note: Since we use custom localStorage auth, request.auth is null.
    match /settings/{document} {
      allow read, write: if true;
    }
    
    // Allow anyone to read/write for now
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
